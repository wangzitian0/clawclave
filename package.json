{
  "name": "clawclave",
  "version": "0.1.0",
  "description": "Discord group operations and onboarding for OpenClaw agent teams.",
  "type": "module",
  "license": "MIT",
  "author": "wangzitian0",
  "homepage": "https://github.com/wangzitian0/clawclave#readme",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/wangzitian0/clawclave.git"
  },
  "bugs": {
    "url": "https://github.com/wangzitian0/clawclave/issues"
  },
  "keywords": [
    "openclaw",
    "openclaw-plugin",
    "discord",
    "discord-bot",
    "ai-agents",
    "agent-orchestration",
    "group-onboarding",
    "discord-community",
    "transcript-memory"
  ],
  "exports": {
    ".": "./index.js",
    "./runtime": "./src/runtime.js",
    "./group-workspace": "./src/group-workspace.js",
    "./sync-group-goals": "./src/sync-group-goals.js",
    "./onboard-discord-group": "./src/onboard-discord-group.js",
    "./audit-discord-group-runtime": "./src/audit-discord-group-runtime.js",
    "./discussion-audits": "./src/discussion-audits.js",
    "./audit-discussion-lifecycle": "./src/audit-discussion-lifecycle.js",
    "./audit-communication-contracts": "./src/audit-communication-contracts.js",
    "./audit-group-orchestration-rules": "./src/audit-group-orchestration-rules.js",
    "./thread-bindings-maintenance": "./src/thread-bindings-maintenance.js"
  },
  "bin": {
    "clawclave": "bin/clawclave.js"
  },
  "files": [
    "bin",
    "index.js",
    "src",
    "docs",
    "examples",
    "schemas",
    "openclaw.plugin.json",
    "CHANGELOG.md",
    "CONTRIBUTING.md",
    "SECURITY.md",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "node --test",
    "coverage": "c8 --all --include 'index.js' --include 'src/**/*.js' --reporter=text --reporter=lcov node --test",
    "coverage:check": "c8 --all --include 'index.js' --include 'src/**/*.js' --reporter=text --reporter=lcov --check-coverage --statements 50 --branches 50 --functions 50 --lines 50 node --test",
    "check": "node --check index.js && node --check src/runtime.js && node --check src/group-workspace.js && node --check src/sync-group-goals.js && node --check src/onboard-discord-group.js && node --check src/audit-discord-group-runtime.js && node --check src/discussion-audits.js && node --check src/audit-discussion-lifecycle.js && node --check src/audit-communication-contracts.js && node --check src/audit-group-orchestration-rules.js && node --check src/thread-bindings-maintenance.js && node --check bin/clawclave.js && node --check test/runtime.test.js",
    "verify": "npm run check && npm test",
    "pack:dry-run": "npm pack --dry-run",
    "prepublishOnly": "npm run verify"
  },
  "openclaw": {
    "extensions": [
      "./index.js"
    ]
  },
  "peerDependencies": {
    "openclaw": ">=2026.5.3"
  },
  "peerDependenciesMeta": {
    "openclaw": {
      "optional": true
    }
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "c8": "^11.0.0"
  }
}
